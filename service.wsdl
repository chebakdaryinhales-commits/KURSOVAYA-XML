<?xml version="1.0" encoding="UTF-8"?>
<definitions name="MyService"
            targetNamespace="http://example.com"
            xmlns="http://xmlsoap.org"
            xmlns:soap="http://xmlsoap.orgsoap/"
            xmlns:tns="http://example.com"
            xmlns:xsd="http://w3.org">

    <!-- Структура входящего XML-запроса -->
    <message name="GetUserDataRequest">
        <part name="userId" type="xsd:string"/>
    </message>

    <!-- Структура исходящего XML-ответа -->
    <message name="GetUserDataResponse">
        <part name="name" type="xsd:string"/>
        <part name="role" type="xsd:string"/>
    </message>

    <!-- Описание операции (метода) службы -->
    <portType name="MyPortType">
        <operation name="GetUserData">
            <input message="tns:GetUserDataRequest"/>
            <output message="tns:GetUserDataResponse"/>
        </operation>
    </portType>

    <!-- Привязка к протоколу SOAP -->
    <binding name="MyBinding" type="tns:MyPortType">
        <soap:binding style="rpc" transport="http://xmlsoap.org"/>
        <operation name="GetUserData">
            <soap:operation soapAction="GetUserData"/>
            <input><soap:body use="encoded" namespace="http://example.com" encodingStyle="http://xmlsoap.org"/></input>
            <output><soap:body use="encoded" namespace="http://example.com" encodingStyle="http://xmlsoap.org"/></output>
        </operation>
    </binding>

    <!-- Физический адрес службы (Endpoint) -->
    <service name="MyService">
        <port name="MyPort" binding="tns:MyBinding">
            <soap:address location="http://localhost:8000/xml-service"/>
        </port>
    </service>
</definitions>
